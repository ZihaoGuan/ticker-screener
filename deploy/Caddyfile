{$APP_FQDN} {
    @api path /api/*
    @health path /healthz

    handle @api {
        reverse_proxy web:8000
    }

    handle @health {
        reverse_proxy web:8000
    }

    handle {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }
}

{$REPORTS_FQDN} {
    root * /artifacts/output
    file_server
}
