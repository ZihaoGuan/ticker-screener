{$APP_FQDN} {
    @api path /api/*
    @health path /healthz
    @assets path /assets/* /favicon.svg

    handle @api {
        reverse_proxy web:8000
    }

    handle @health {
        reverse_proxy web:8000
    }

    handle @assets {
        root * /srv/frontend
        header Cache-Control "public, max-age=31536000, immutable"
        file_server
    }

    handle {
        root * /srv/frontend
        header Cache-Control "no-store"
        try_files {path} /index.html
        file_server
    }
}

{$REPORTS_FQDN} {
    root * /artifacts/output
    file_server
}
