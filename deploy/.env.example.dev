# Development Environment Configuration
# Copy this to .env.dev and update with your dev values

# Database
POSTGRES_DB=ticker_screener_dev
POSTGRES_USER=screener_dev
POSTGRES_PASSWORD=dev_password_change_me

# Application
APP_ENV=development
APP_TITLE=Ticker Screener (Dev)
TICKER_SCREENER_DATABASE_URL=postgresql://screener_dev:dev_password_change_me@db:5432/ticker_screener_dev

# Caddy
APP_FQDN=dev.ticker.example.com
REPORTS_FQDN=dev-reports.ticker.example.com
