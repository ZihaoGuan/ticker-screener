APP_ENV=prod
APP_TITLE=Ticker Screener
APP_DOMAIN=example.com
APP_FQDN=app.example.com
REPORTS_FQDN=reports.example.com

POSTGRES_DB=ticker_screener
POSTGRES_USER=ticker
POSTGRES_PASSWORD=change_me

TICKER_SCREENER_DATABASE_URL=postgresql://ticker:change_me@db:5432/ticker_screener

WEBAPP_BASE_URL=https://app.example.com
WEBAPP_AUTH_SECRET_KEY=change_me_to_a_long_random_secret
WEBAPP_AUTH_SESSION_COOKIE_NAME=ticker_screener_session
WEBAPP_AUTH_SESSION_TTL_HOURS=720
WEBAPP_AUTH_MAGIC_LINK_TTL_MINUTES=30
WEBAPP_AUTH_COOKIE_SECURE=true
WEBAPP_AUTH_COOKIE_SAMESITE=lax
WEBAPP_AUTH_BOOTSTRAP_ADMIN_EMAILS=admin@example.com

WEBAPP_SMTP_HOST=smtp.example.com
WEBAPP_SMTP_PORT=587
WEBAPP_SMTP_USERNAME=
WEBAPP_SMTP_PASSWORD=
WEBAPP_SMTP_FROM_ADDRESS=no-reply@example.com
WEBAPP_SMTP_USE_TLS=true
WEBAPP_SMTP_USE_SSL=false
